DCEMLID.ASM



      1				     ; DCEMLID.ASM - ODI MLID Driver for Serial/Parallel Direct	Cable Connection
      2				     ; Implements point-to-point IPX networking	over null-modem	or parallel cables
      3				     ; Supports	configurable MAC, baud rates, flow control, and	automatic UMB loading
      4				     ; 8086 CPU	compatible (runs on IBM	PC/XT and all compatibles)
      5
      6				     ; Build as	.COM file with:	TASM /m2 /jJUMPS DCEMLID.ASM &&	TLINK /t DCEMLID.OBJ
      7				     ; Home of sourcecode: https://github.com/smarthomerocks/dcemlid
      8				     ;
      9				     ; For specification of LSL, MLID, ODI and IPX,see:	dos_pstack.txt
     10
     11
     12
     13				     .8086			     ; 8086 CPU	instructions only
     14
     15	0000			     CODE    SEGMENT
     16					     ASSUME CS:CODE, DS:CODE, ES:CODE, SS:CODE
     17					     ORG 100h		     ; .COM file starts	at offset 100h
     18
     19				     ;=============================================================================
     20				     ; Constants and Equates
     21				     ;=============================================================================
     22
     23				     ; Driver Information
     24	      =0100		     DRIVER_VERSION  EQU 0100h		     ; Version 1.00
     25	      =0240		     MTU_SIZE	     EQU 576		     ; Maximum Transmission Unit (IPX max)
     26
     27				     ; Multiplex and LSL Constants
     28	      =C0A0		     MULTIPLEX_ID    EQU 0C0A0h		     ; Our multiplex ID
     29	      =C000		     LSL_CHECK	     EQU 0C000h		     ; Check if	LSL loaded
     30	      =C001		     LSL_REGISTER    EQU 0C001h		     ; Register	MLID with LSL
     31	      =C003		     LSL_GET_CONFIG  EQU 0C003h		     ; Get configuration from LSL
     32
     33				     ; Frame Protocol Constants
     34	      =00C0		     FRAME_START     EQU 0C0h		     ; SLIP-style frame	delimiter
     35	      =00DB		     FRAME_ESC	     EQU 0DBh		     ; Escape character
     36	      =00DC		     ESC_START	     EQU 0DCh		     ; Escaped START
     37	      =00DD		     ESC_ESC	     EQU 0DDh		     ; Escaped ESC
     38	      =00DE		     ESC_XON	     EQU 0DEh		     ; Escaped XON
     39	      =00DF		     ESC_XOFF	     EQU 0DFh		     ; Escaped XOFF
     40	      =0011		     XON_CHAR	     EQU 011h		     ; XON (Ctrl+Q)
     41	      =0013		     XOFF_CHAR	     EQU 013h		     ; XOFF (Ctrl+S)
     42	      =0006		     ACK_CHAR	     EQU 006h		     ; ACK
     43	      =0015		     NAK_CHAR	     EQU 015h		     ; NAK
     44
     45				     ; UART Register Offsets
     46	      =0000		     UART_RBR	     EQU 0		     ; Receiver	Buffer (Read)
     47	      =0000		     UART_THR	     EQU 0		     ; Transmitter Holding (Write)
     48	      =0001		     UART_IER	     EQU 1		     ; Interrupt Enable
     49	      =0002		     UART_IIR	     EQU 2		     ; Interrupt Identification	(Read)
     50	      =0002		     UART_FCR	     EQU 2		     ; FIFO Control (Write)
     51	      =0003		     UART_LCR	     EQU 3		     ; Line Control
     52	      =0004		     UART_MCR	     EQU 4		     ; Modem Control
     53	      =0005		     UART_LSR	     EQU 5		     ; Line Status
     54	      =0006		     UART_MSR	     EQU 6		     ; Modem Status
     55	      =0007		     UART_SCR	     EQU 7		     ; Scratch Register
     56
     57				     ; UART Configuration Values
Turbo Assembler	 Version 4.1	    03/03/26 01:07:02	    Page 2
DCEMLID.ASM



     58	      =0080		     LCR_DLAB	     EQU 80h		     ; Divisor Latch Access Bit
     59	      =0003		     LCR_8N1	     EQU 03h		     ; 8 data bits, no parity, 1 stop
     60	      =0001		     FCR_ENABLE	     EQU 01h		     ; Enable FIFO
     61	      =0006		     FCR_CLEAR	     EQU 06h		     ; Clear TX/RX FIFOs
     62	      =0080		     FCR_TRIGGER_8   EQU 80h		     ; 8-byte trigger level
     63	      =0001		     MCR_DTR	     EQU 01h		     ; Data Terminal Ready
     64	      =0002		     MCR_RTS	     EQU 02h		     ; Request To Send
     65	      =0008		     MCR_OUT2	     EQU 08h		     ; OUT2 (enable IRQ)
     66
     67				     ; Parallel	Port Register Offsets
     68	      =0000		     LPT_DATA	     EQU 0		     ; Data register
     69	      =0001		     LPT_STATUS	     EQU 1		     ; Status register
     70	      =0002		     LPT_CONTROL     EQU 2		     ; Control register
     71	      =0003		     LPT_EPP_ADDR    EQU 3		     ; EPP address port
     72	      =0004		     LPT_EPP_DATA    EQU 4		     ; EPP data	port
     73	      =0402		     LPT_ECR	     EQU 402h		     ; Extended	Control	Register
     74
     75				     ; Parallel	Port Control Bits
     76	      =0001		     LPT_CTRL_STROBE EQU 01h		     ; Strobe
     77	      =0002		     LPT_CTRL_AUTOFD EQU 02h		     ; Auto Line Feed
     78	      =0004		     LPT_CTRL_INIT   EQU 04h		     ; Initialize
     79	      =0008		     LPT_CTRL_SELECT EQU 08h		     ; Select In
     80	      =0010		     LPT_CTRL_IRQ    EQU 10h		     ; Enable IRQ
     81	      =0020		     LPT_CTRL_BIDIR  EQU 20h		     ; Bidirectional enable (PS/2)
     82
     83				     ; Buffer Sizes
     84	      =1000		     RX_BUFFER_SIZE  EQU 4096		     ; 4KB receive circular buffer
     85	      =0800		     TX_BUFFER_SIZE  EQU 2048		     ; 2KB transmit queue
     86
     87				     ; Timing Constants
     88	      =00C8		     RETRY_TIMEOUT   EQU 200		     ; 200ms timeout
     89	      =0002		     MAX_RETRIES     EQU 2		     ; Maximum retry attempts
     90
     91				     ; MLID Control Function Codes
     92	      =0001		     MLID_RESET	     EQU 01h
     93	      =0002		     MLID_SHUTDOWN   EQU 02h
     94	      =0005		     MLID_GET_STATS  EQU 05h
     95	      =0006		     MLID_SEND_PKT   EQU 06h
     96	      =0007		     MLID_REG_RX     EQU 07h
     97
     98				     ; ECB (Event Control Block) Structure Offsets
     99	      =0000		     ECB_Link	     EQU 0		     ; DD - Link to next ECB
    100	      =0004		     ECB_ESR	     EQU 4		     ; DD - Event Service Routine
    101	      =0008		     ECB_InUse	     EQU 8		     ; DB - In use flag
    102	      =0009		     ECB_CompCode    EQU 9		     ; DB - Completion code
    103	      =000A		     ECB_Socket	     EQU 10		     ; DW - Socket number
    104	      =000C		     ECB_IPXWork     EQU 12		     ; 4 bytes - IPX workspace
    105	      =0010		     ECB_DriverWork  EQU 16		     ; 12 bytes	- Driver workspace
    106	      =001C		     ECB_ImmAddr     EQU 28		     ; 6 bytes - Immediate address
    107	      =0022		     ECB_FragCount   EQU 34		     ; DW - Fragment count
    108	      =0024		     ECB_FragList    EQU 36		     ; Fragment	descriptors start
    109
    110				     ; Fragment	Descriptor Offsets (each 6 bytes)
    111	      =0000		     FRAG_Addr	     EQU 0		     ; DD - Fragment address
    112	      =0004		     FRAG_Size	     EQU 4		     ; DW - Fragment size
    113
    114				     ; ECB Completion Codes
