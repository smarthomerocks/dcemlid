   4040	39D0  50			 push	 ax
   4041	39D1  52			 push	 dx
   4042	39D2  01 07			 add	 word ptr [bx],	ax   ; Add low word
   4043	39D4  11 57 02			 adc	 word ptr [bx+2], dx ; Add high	word with carry
