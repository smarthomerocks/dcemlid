    115	      =0000		     ECB_SUCCESS     EQU 00h		     ; Successful
    116	      =00FC		     ECB_CANCELLED   EQU 0FCh		     ; Cancelled by application
    117	      =00FD		     ECB_HARDWARE    EQU 0FDh		     ; Hardware	error
    118	      =00FE		     ECB_BAD_PKT     EQU 0FEh		     ; Malformed packet
    119	      =00FF		     ECB_OVERFLOW    EQU 0FFh		     ; Packet overflow
