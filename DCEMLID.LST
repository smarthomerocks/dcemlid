   3888					 ; ===== DEREGISTER FROM LSL =====
   3889					 ; Call	DeregisterMLID via LSL MLID Support entry point
   3890					 ; The entry point is in the TSR's LSLInfoBuf.LSLEntryPoint
   3891					 ; BX =	0006h (DeregisterMLID =	MLIDSUP_DEREGISTER_MLID), AX = board number
