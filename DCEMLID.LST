   4069	39E3  8B 4C 02			 mov	 cx, word ptr [si+2]
   4070
   4071					 ; Check for end marker	(baud rate = 0)
   4072	39E6  0B C1			 or	 ax, cx
   4073	39E8  74 1B			 jz	 BaudNotFound
   4074
   4075					 ; Compare with	configured baud	rate
   4076	39EA  8B 04			 mov	 ax, word ptr [si]
   4077	39EC  8B 4C 02			 mov	 cx, word ptr [si+2]
   4078	39EF  3B 06 010Er		 cmp	 ax, word ptr CfgData.BaudRate
   4079	39F3  75 0B			 jne	 BaudNext
   4080	39F5  3B 0E 0110r		 cmp	 cx, word ptr CfgData.BaudRate+2
   4081	39F9  75 05			 jne	 BaudNext
   4082
   4083					 ; Found match - get divisor
   4084	39FB  8B 5C 04			 mov	 bx, word ptr [si+4]
   4085	39FE  5F			 pop	 di
   4086	39FF  C3			 ret
